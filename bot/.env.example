BOT_TOKEN=your_bot_token_here
ADMIN_IDS=123456789,987654321
PAYME_TOKEN=your_payme_token
CLICK_TOKEN=your_click_token
BANK_CARD=8600_0000_0000_0000
CHANNEL_ID=@your_channel
SUPPORT_USERNAME=@admin_username

# ===== AI PROVIDER =====
# Hozir "gemini" ishlamoqda. Kelajakda "openai" ga o'tish mumkin.
AI_PROVIDER=gemini

# ===== GEMINI (ASOSIY - HOZIR ISHLAYDI) =====
# Bir nechta kalit qo'yish mumkin (vergul bilan): key1,key2,key3
GEMINI_API_KEY=your_gemini_api_key_here

# ===== PEXELS (IXTIYORIY) — slaydlarga real rasmlar qo'shish uchun =====
# Bepul kalit oling: https://www.pexels.com/api/
# Bo'sh qoldirsangiz — slaydlar chiroyli dizayn elementlari bilan yaratiladi
PEXELS_API_KEY=

# ===== OPENAI (O'CHIRILGAN - KELAJAKDA ISHLATILADI) =====
# AI_PROVIDER=openai qilganda ishlaydi
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
